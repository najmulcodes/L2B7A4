# =============================================================================
# GearUp Backend - Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.
# =============================================================================

# --- App ---
NODE_ENV=development
PORT=5000
# Public base URL of THIS API (no trailing slash). SSLCommerz callback URLs
# are built from this, so it must be reachable from the internet in
# production (use your Render/Vercel URL). For local testing with a real
# sandbox payment, expose your local server with a tool like ngrok and put
# that URL here instead.
APP_BASE_URL=http://localhost:5000

# --- Database (PostgreSQL via Prisma) ---
# DATABASE_URL: used by the app at runtime (can be a pooled connection,
# e.g. Neon/Supabase's "-pooler" endpoint - safe for serverless deploys).
# DIRECT_URL: used by the Prisma CLI for migrations (must be a DIRECT,
# non-pooled connection). If your Postgres provider doesn't distinguish
# between the two, set both to the same value.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/gearup?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/gearup?sslmode=require"
DATABASE_POOL_MAX=10

# --- JWT Auth ---
# Generate strong secrets, e.g.: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_a_random_64_char_hex_string
JWT_REFRESH_SECRET=replace_with_a_different_random_64_char_hex_string
JWT_ACCESS_EXPIRES_IN_SECONDS=86400
JWT_REFRESH_EXPIRES_IN_SECONDS=2592000
BCRYPT_SALT_ROUNDS=12

# --- CORS ---
# Comma-separated list of allowed origins, or "*" to allow all (fine for an
# assignment/demo; restrict this in a real production deployment).
CORS_ORIGIN=*

# --- SSLCommerz Payment Gateway ---
# Register a free sandbox merchant account at:
# https://developer.sslcommerz.com/registration/
# (instant approval, no real business verification needed for sandbox)
SSLCOMMERZ_STORE_ID=your_sandbox_store_id
SSLCOMMERZ_STORE_PASSWORD=your_sandbox_store_password
SSLCOMMERZ_IS_LIVE=false

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20
