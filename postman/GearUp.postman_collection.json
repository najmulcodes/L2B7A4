        {
          "name": "Login (Admin - from seed data)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Run this first to populate {{accessToken}} for the Admin folder requests.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@gearup.com\",\n  \"password\": \"Password123\"\n}"
            },
            "auth": {
              "type": "noauth"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  if (json.data && json.data.accessToken) {",
                  "    pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "  }",
                  "  if (json.data && json.data.refreshToken) {",
                  "    pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
