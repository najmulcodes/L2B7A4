{
  "info": {
    "name": "GearUp API",
    "description": "Sports & outdoor gear rental marketplace backend. Set {{baseUrl}} to your local (http://localhost:5000/api) or deployed URL. Run the Auth > Login requests first to populate {{accessToken}} automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api"
    },
    {
      "key": "serverUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    },
    {
      "key": "categoryId",
      "value": ""
    },
    {
      "key": "gearItemId",
      "value": ""
    },
    {
      "key": "rentalOrderId",
      "value": ""
    },
    {
      "key": "paymentTransactionId",
      "value": ""
    },
    {
      "key": "paymentId",
      "value": ""
    },
    {
      "key": "userId",
      "value": ""
    },
    {
      "key": "reviewId",
      "value": ""
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
