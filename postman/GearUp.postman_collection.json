              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Customer\",\n  \"email\": \"test.customer@example.com\",\n  \"password\": \"Password123\",\n  \"phone\": \"01900000001\",\n  \"role\": \"CUSTOMER\",\n  \"address\": \"Dhaka, Bangladesh\"\n}"
